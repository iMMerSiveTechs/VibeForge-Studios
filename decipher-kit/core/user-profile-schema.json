{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DecipherKit User Profile",
  "description": "Per-user handwriting profile for personalized transcription with glyph mapping and accuracy tracking",
  "type": "object",
  "required": ["userId", "displayName", "created", "calibrationComplete", "glyphMap", "stats"],
  "properties": {
    "userId": {
      "type": "string",
      "description": "Unique identifier for the user, typically UUID v4",
      "pattern": "^[a-f0-9-]{36}$|^[a-zA-Z0-9_-]{20,}$"
    },
    "displayName": {
      "type": "string",
      "description": "User-friendly name for the profile",
      "minLength": 1,
      "maxLength": 255
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when profile was created"
    },
    "lastModified": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last profile update"
    },
    "calibrationComplete": {
      "type": "boolean",
      "description": "Whether the user has completed the initial calibration sequence"
    },
    "calibrationScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score from calibration phase (0.0-1.0), where 1.0 is perfect calibration"
    },
    "calibrationDate": {
      "type": "string",
      "format": "date-time",
      "description": "When calibration was last completed or updated"
    },
    "glyphMap": {
      "$ref": "#/definitions/GlyphMap"
    },
    "stats": {
      "$ref": "#/definitions/Statistics"
    },
    "correctionHistory": {
      "$ref": "#/definitions/CorrectionHistory"
    },
    "vocabulary": {
      "$ref": "#/definitions/VocabularyProfile"
    },
    "settings": {
      "$ref": "#/definitions/UserSettings"
    }
  },
  "definitions": {
    "GlyphMap": {
      "type": "object",
      "description": "Personalized mapping of handwritten letter forms to canonical characters",
      "properties": {
        "version": {
          "type": "string",
          "description": "Version identifier for glyph model (e.g., '1.0', '1.1')"
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When this glyph map was generated or last updated"
        },
        "basedOnSamples": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of handwriting samples used to generate this map"
        },
        "characters": {
          "type": "object",
          "description": "Mapping of individual characters to their glyph signatures",
          "additionalProperties": {
            "$ref": "#/definitions/CharacterGlyph"
          }
        },
        "ligatures": {
          "type": "object",
          "description": "Common letter combinations and their handwritten patterns",
          "additionalProperties": {
            "$ref": "#/definitions/LigatureGlyph"
          }
        },
        "confusionPairs": {
          "type": "array",
          "description": "Letter pairs this writer frequently confuses",
          "items": {
            "$ref": "#/definitions/ConfusionPair"
          }
        },
        "penPressureProfile": {
          "$ref": "#/definitions/PenPressureProfile"
        },
        "slantAngle": {
          "type": "number",
          "description": "Average slant angle in degrees (-20 to +20 typically)"
        },
        "baselineVariance": {
          "type": "number",
          "description": "Standard deviation of baseline position (pixels)"
        }
      },
      "required": ["version", "generatedAt", "characters"]
    },
    "CharacterGlyph": {
      "type": "object",
      "description": "Learned pattern for a single character",
      "properties": {
        "character": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1,
          "description": "The ASCII character this glyph represents"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence in this glyph pattern (based on sample consistency)"
        },
        "variants": {
          "type": "array",
          "description": "Known variations of this character in this user's handwriting",
          "items": {
            "$ref": "#/definitions/GlyphVariant"
          }
        },
        "frequency": {
          "type": "number",
          "minimum": 0,
          "description": "How often this character appears in calibration samples"
        },
        "commonMisidentifications": {
          "type": "array",
          "description": "Characters this one is commonly misidentified as",
          "items": {
            "type": "object",
            "properties": {
              "character": { "type": "string" },
              "frequency": { "type": "number" }
            }
          }
        }
      },
      "required": ["character", "confidence"]
    },
    "GlyphVariant": {
      "type": "object",
      "description": "A specific handwritten instance of a character",
      "properties": {
        "variantId": {
          "type": "string",
          "description": "Unique identifier for this variant"
        },
        "formSignature": {
          "type": "string",
          "description": "Encoded visual signature of the glyph form (feature vector)"
        },
        "observationCount": {
          "type": "integer",
          "minimum": 1,
          "description": "How many times this exact variant was observed"
        },
        "context": {
          "type": "string",
          "enum": ["standalone", "initial", "medial", "final", "uppercase_adjacent", "lowercase_adjacent"],
          "description": "Position in word where this variant typically appears"
        }
      },
      "required": ["variantId", "formSignature"]
    },
    "LigatureGlyph": {
      "type": "object",
      "description": "Pattern for connected letter sequences",
      "properties": {
        "sequence": {
          "type": "string",
          "minLength": 2,
          "description": "The letter sequence (e.g., 'th', 'er')"
        },
        "formSignature": {
          "type": "string",
          "description": "Encoded visual signature of the ligature"
        },
        "frequency": {
          "type": "number",
          "description": "Relative frequency of this ligature in writer's samples"
        },
        "isConnected": {
          "type": "boolean",
          "description": "Whether letters are typically joined in this user's writing"
        }
      },
      "required": ["sequence", "formSignature"]
    },
    "ConfusionPair": {
      "type": "object",
      "description": "Characters that are frequently misidentified",
      "properties": {
        "char1": { "type": "string", "minLength": 1, "maxLength": 1 },
        "char2": { "type": "string", "minLength": 1, "maxLength": 1 },
        "confusionRate": { "type": "number", "minimum": 0, "maximum": 1 },
        "context": {
          "type": "string",
          "description": "Contextual notes (e.g., 'lowercase_a_and_u_in_cursive')"
        }
      },
      "required": ["char1", "char2", "confusionRate"]
    },
    "PenPressureProfile": {
      "type": "object",
      "description": "Characteristics of pen pressure variation",
      "properties": {
        "averagePressure": { "type": "number", "minimum": 0, "maximum": 1 },
        "pressureVariance": { "type": "number", "minimum": 0 },
        "supportsVariablePressure": { "type": "boolean" }
      }
    },
    "Statistics": {
      "type": "object",
      "description": "Usage and accuracy statistics for this user",
      "properties": {
        "totalTranscriptions": {
          "type": "integer",
          "minimum": 0,
          "description": "Cumulative count of transcriptions processed"
        },
        "totalCorrections": {
          "type": "integer",
          "minimum": 0,
          "description": "Total user corrections applied to transcriptions"
        },
        "accuracyRate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Overall character-level accuracy (1 - (corrections/characters))"
        },
        "recentAccuracy": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Accuracy rate for last 100 transcriptions (moving window)"
        },
        "mostCommonErrors": {
          "type": "array",
          "description": "Most frequently corrected character confusions",
          "items": {
            "type": "object",
            "properties": {
              "predicted": { "type": "string", "minLength": 1, "maxLength": 1 },
              "actual": { "type": "string", "minLength": 1, "maxLength": 1 },
              "frequency": { "type": "integer", "minimum": 1 }
            },
            "required": ["predicted", "actual", "frequency"]
          }
        },
        "lastUsed": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of most recent transcription"
        },
        "streakDaysActive": {
          "type": "integer",
          "minimum": 0,
          "description": "Consecutive days with at least one transcription"
        },
        "totalTimeInvested": {
          "type": "integer",
          "minimum": 0,
          "description": "Total minutes spent in calibration and correction loops"
        }
      },
      "required": ["totalTranscriptions", "totalCorrections", "accuracyRate"]
    },
    "CorrectionHistory": {
      "type": "object",
      "description": "Aggregated correction patterns for continuous improvement",
      "properties": {
        "correctionsByDate": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "date": { "type": "string", "format": "date" },
              "count": { "type": "integer" },
              "topErrors": {
                "type": "array",
                "maxItems": 5,
                "items": {
                  "type": "object",
                  "properties": {
                    "predicted": { "type": "string" },
                    "actual": { "type": "string" },
                    "count": { "type": "integer" }
                  }
                }
              }
            }
          }
        },
        "correctionPatterns": {
          "type": "object",
          "description": "Temporal and contextual correction patterns",
          "properties": {
            "characterErrors": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "totalCount": { "type": "integer" },
                  "lastCorrected": { "type": "string", "format": "date-time" }
                }
              }
            },
            "contextDependentErrors": {
              "type": "array",
              "description": "Errors that occur mainly in specific contexts",
              "items": {
                "type": "object",
                "properties": {
                  "error": { "type": "string" },
                  "context": { "type": "string" },
                  "frequency": { "type": "integer" }
                }
              }
            }
          }
        },
        "feedbackGaps": {
          "type": "array",
          "description": "Detected gaps in training data (rarely-seen characters, contexts)",
          "items": {
            "type": "object",
            "properties": {
              "character": { "type": "string" },
              "context": { "type": "string" },
              "recommendedAction": { "type": "string" }
            }
          }
        }
      }
    },
    "VocabularyProfile": {
      "type": "object",
      "description": "Domain-specific vocabulary preferences and context",
      "properties": {
        "dominantDomains": {
          "type": "array",
          "description": "Identified domains (medical, legal, technical, etc.)",
          "items": {
            "type": "object",
            "properties": {
              "domain": { "type": "string" },
              "confidence": { "type": "number" }
            }
          }
        },
        "customDictionary": {
          "type": "object",
          "description": "User-defined terms and proper nouns",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "definition": { "type": "string" },
              "frequency": { "type": "integer" },
              "context": { "type": "string" }
            }
          }
        },
        "abbreviationPreferences": {
          "type": "object",
          "description": "Common abbreviations in this user's writing",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "UserSettings": {
      "type": "object",
      "description": "User preferences for transcription behavior",
      "properties": {
        "autoCorrectEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Whether to auto-correct low-confidence predictions"
        },
        "confidenceThreshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.85,
          "description": "Confidence threshold for accepting predictions without review"
        },
        "preserveFormatting": {
          "type": "boolean",
          "default": true,
          "description": "Preserve spatial layout and paragraph structure"
        },
        "includeConfidenceScores": {
          "type": "boolean",
          "default": false,
          "description": "Include confidence metadata in transcription output"
        },
        "handednessHint": {
          "type": "string",
          "enum": ["right", "left", "ambidextrous"],
          "description": "User's dominant hand (for spatial analysis)"
        },
        "writingStyle": {
          "type": "string",
          "enum": ["print", "cursive", "mixed"],
          "default": "mixed"
        }
      }
    }
  }
}
